<Window x:Class="BusScheduleApp.LogInForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизація" Height="240" Width="280" WindowStyle="ToolWindow" WindowStartupLocation="CenterScreen">
    <StackPanel Margin="20">
        <Label Content="Логін:"/>
        <TextBox x:Name="logTextBox" Margin="0,5"/>
        <Label Content="Пароль:"/>
        <PasswordBox x:Name="passwordTextBox" Margin="0,5"/>
        <Button x:Name="okButton" Content="Вхід" Click="OkButton_Click" Margin="0,10" Height="30" IsDefault="True"/>
    </StackPanel>
</Window>